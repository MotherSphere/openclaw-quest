{
  "name": "openclaw-quest",
  "version": "0.1.1",
  "description": "RPG-style observability dashboard for OpenClaw agents — packaged as a native OpenClaw plugin.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MotherSphere/openclaw-quest.git",
    "directory": "server-ts"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "observability",
    "rpg",
    "dashboard"
  ],
  "files": [
    "src",
    "prompts",
    "dist-frontend",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "openclaw": {
    "extensions": [
      "./src/plugin-entry.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.20",
      "minGatewayVersion": "2026.4.20"
    },
    "build": {
      "openclawVersion": "2026.4.20",
      "pluginSdkVersion": "2026.4.20"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.20"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.0",
    "chokidar": "^4.0.0",
    "fastify": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "openclaw": "2026.4.21",
    "typescript": "^5.6.0"
  }
}
