# OpenClaw Quest Dashboard — Environment Variables

# Backend URL for Vite dev server proxy
VITE_BACKEND_URL=http://localhost:8420

# API key for backend authentication (set in server/.env too)
QUEST_API_KEY=your_api_key_here

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_user_id_here

# --- Agent runtime (OpenClaw) ---
# Override if openclaw is not at /usr/bin/openclaw or $PATH.
# QUEST_OPENCLAW_BIN=/usr/bin/openclaw
# Override if ~/.openclaw lives somewhere else.
# QUEST_OPENCLAW_HOME=~/.openclaw
# Python site-packages glob. OpenClaw is Node-based so this is normally
# empty; retained only for compatibility with the legacy (Hermes Agent)
# spawn path which Phase 2 will replace.
# QUEST_OPENCLAW_SITE_PACKAGES_GLOB=
