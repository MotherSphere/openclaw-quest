# OpenClaw Quest — Environment Variables
# All values optional. Defaults shown in comments.

# --- Dev server ---
# Backend URL that the Vite dev server proxies /api and /ws to.
VITE_BACKEND_URL=http://localhost:8420

# --- Backend ---
# Optional API key. If set, POST /api/* from different origins must send
# X-API-Key: <value>. Leave empty for local dev.
QUEST_API_KEY=

# Must be 1 for the CYCLE button to actually spawn the cycle runner.
# Default is 0 so a fresh clone won't burn LLM tokens by accident.
QUEST_CYCLE_ENABLED=1

# Backend listen address (defaults: 8420, 0.0.0.0).
# QUEST_PORT=8420
# QUEST_HOST=0.0.0.0

# --- OpenClaw runtime ---
# Override the `openclaw` binary path if not at /usr/bin/openclaw or $PATH.
# QUEST_OPENCLAW_BIN=/usr/bin/openclaw

# Override the OpenClaw data dir. Only used by the legacy skill_classify
# code path (inert in practice).
# QUEST_OPENCLAW_HOME=~/.openclaw

# Which OpenClaw agent to invoke for cycles + NPC dialogue.
# QUEST_CYCLE_AGENT_ID=main

# Thinking level per call: off | minimal | low | medium | high | xhigh
# QUEST_CYCLE_THINKING=minimal

# Per-call timeout in seconds for `openclaw agent`.
# QUEST_CYCLE_LLM_TIMEOUT=90

# --- Telegram (optional) ---
# Only used if you wire the Telegram notifier.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_USER_ID=
